{
  "description": "ARETE security & audit hooks — bash auditing, secret detection, protected-path guards, tool logging, session boundaries.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/audit-bash.sh\"" },
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/no-force-push.sh\"" },
          { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/detect-secrets.py\"" }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/protected-paths.sh\"" },
          { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/validate-files.py\"" },
          { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/detect-secrets.py\"" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/tool-logger.sh\"" }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session-logger.sh\"" }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session-logger.sh\"" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/detect-secrets.py\"" },
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/wrap-it-up.sh\"" }
        ]
      }
    ]
  }
}
